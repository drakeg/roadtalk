# Copy this file to .env for local development only.
# Do not reuse these values in a shared, field-test, or production environment.

POSTGRES_DB=roadtalk
POSTGRES_USER=roadtalk
POSTGRES_PASSWORD=roadtalk_local_only_change_me
POSTGRES_PORT=5432

# Redis is optional and starts only through the redis Compose profile.
REDIS_PORT=6379

# Future backend/mobile deliverables will consume these local endpoints.
DATABASE_URL=postgresql+psycopg://roadtalk:roadtalk_local_only_change_me@localhost:5432/roadtalk
REDIS_URL=redis://localhost:6379/0
API_BASE_URL=http://localhost:8000/api/v1
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Backend foundation configuration.
ROADTALK_ENVIRONMENT=local
ROADTALK_VERSION=0.1.0
ROADTALK_LOG_LEVEL=INFO
ROADTALK_DOCS_ENABLED=true
ROADTALK_DATABASE_ECHO=false
ROADTALK_DATABASE_CHECK_ENABLED=true

# Local authentication secrets only. Shared environments must inject unique secrets.
ROADTALK_TOKEN_SIGNING_KEY=local-only-signing-key-change-me
ROADTALK_REFRESH_TOKEN_PEPPER=local-only-refresh-pepper-change-me
ROADTALK_RECOVERY_KEY_PEPPER=local-only-recovery-pepper-change-me
ROADTALK_ACCESS_TOKEN_TTL_SECONDS=900
ROADTALK_REFRESH_TOKEN_TTL_SECONDS=2592000

# Versioned foreground-location quality, expiry, and single-process abuse controls.
# These use the existing API and PostgreSQL only; no cache or managed service is required.
ROADTALK_LOCATION_POLICY_VERSION=location-v1
ROADTALK_LOCATION_DISCLOSURE_VERSION=location-disclosure-v1
ROADTALK_LOCATION_MAX_SAMPLE_AGE_SECONDS=60
ROADTALK_LOCATION_MAX_FUTURE_SECONDS=10
ROADTALK_LOCATION_MAX_USABLE_ACCURACY_M=100
ROADTALK_LOCATION_MAX_RETAINED_ACCURACY_M=1000
ROADTALK_LOCATION_MAX_REPORTED_SPEED_MPS=100
ROADTALK_LOCATION_MAX_PLAUSIBLE_SPEED_MPS=100
ROADTALK_LOCATION_PLAUSIBILITY_SLACK_M=250
ROADTALK_LOCATION_USABLE_TTL_SECONDS=120
ROADTALK_LOCATION_DEGRADED_TTL_SECONDS=60
ROADTALK_LOCATION_CROSS_DEVICE_NEWER_SECONDS=1
ROADTALK_LOCATION_MUTATION_LIMIT=30
ROADTALK_LOCATION_MUTATION_WINDOW_SECONDS=60
ROADTALK_LOCATION_NEARBY_READ_LIMIT=60
ROADTALK_LOCATION_NEARBY_READ_WINDOW_SECONDS=60
ROADTALK_LOCATION_NEARBY_RADIUS_M=5000
ROADTALK_LOCATION_NEARBY_MANY_THRESHOLD=5


# Sprint 4 PTT defaults are intentionally provider-disabled and cost $0.
# Live provider URL/key/secret variables are omitted until separate activation approval.
ROADTALK_PTT_POLICY_VERSION=ptt-v1
ROADTALK_PTT_RECEIVE_GRANT_TTL_SECONDS=300
ROADTALK_PTT_TRANSMIT_GRANT_TTL_SECONDS=30
ROADTALK_PTT_MEDIA_PROVIDER_ENABLED=false
ROADTALK_PTT_MEDIA_PROVIDER=disabled
